# Contact Enrichment Engine Configuration Template
# Rename this file to .env and fill in your credentials.

# --- General Configuration ---
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FILE=logs/enrichment_engine.log

# --- Database (PostgreSQL) Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=contact_enrichment
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# --- Queue & Cache (Redis) Configuration ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Search & Scraping Configuration ---
# API keys for search engines or proxies
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=

# Proxy configurations (e.g., Bright Data, Smartproxy)
PROXY_ENABLED=false
PROXY_URL=http://username:password@proxy_host:proxy_port

# Playwright settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# --- AI & Extraction Configuration ---
# LLM APIs for structured extraction
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Output Settings ---
DEFAULT_OUTPUT_FORMAT=xlsx
BATCH_SIZE=50
